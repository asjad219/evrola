# Frontend Environment Variables

# Backend API URL (local development only)
VITE_BACKEND_URL=http://localhost:3001

# ===== BACKEND / SERVERLESS FUNCTION VARIABLES =====
# These should be set in Vercel Dashboard under Project Settings > Environment Variables

# Gmail Configuration
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password

# Google Sheets Configuration
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Notification Email
NOTIFICATION_EMAIL=admin@example.com

# Frontend URL (for CORS)
FRONTEND_URL=https://your-domain.vercel.app

